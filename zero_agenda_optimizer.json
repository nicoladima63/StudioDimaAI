{
    "name": "agenda_optimizer",
    "description": "Analizza agenda odontoiatrica e identifica inefficienze, buchi produttivi e suggerimenti operativi",
    "version": "1.0",
    "input_schema": {
        "type": "object",
        "properties": {
            "appointments": {
                "type": "array",
                "description": "Lista appuntamenti",
                "items": {
                    "type": "object",
                    "properties": {
                        "start": {
                            "type": "string",
                            "format": "date-time"
                        },
                        "end": {
                            "type": "string",
                            "format": "date-time"
                        },
                        "patient_id": {
                            "type": "string"
                        },
                        "treatment": {
                            "type": "string"
                        },
                        "duration_minutes": {
                            "type": "number"
                        },
                        "chair": {
                            "type": "string"
                        },
                        "status": {
                            "type": "string"
                        }
                    },
                    "required": [
                        "start",
                        "end",
                        "duration_minutes"
                    ]
                }
            },
            "working_hours": {
                "type": "object",
                "properties": {
                    "start": {
                        "type": "string"
                    },
                    "end": {
                        "type": "string"
                    }
                }
            },
            "kpi": {
                "type": "object",
                "description": "KPI già calcolati dal backend"
            }
        },
        "required": [
            "appointments"
        ]
    },
    "system_prompt": "Sei un consulente esperto di gestione di studi dentistici. Analizzi l'agenda giornaliera e identifichi inefficienze operative, buchi produttivi e opportunità di ottimizzazione. Devi fornire output strutturato, concreto e operativo, evitando spiegazioni generiche.",
    "instructions": [
        "Analizza la distribuzione temporale degli appuntamenti",
        "Identifica buchi tra appuntamenti superiori a 15 minuti",
        "Valuta se i buchi sono utilizzabili (>= 30 minuti)",
        "Individua cluster inefficienti (es. appuntamenti troppo distanziati)",
        "Segnala sovraccarichi o sotto-utilizzo",
        "Suggerisci azioni concrete (es. inserire igiene, controlli, urgenze)",
        "Se disponibili KPI, usali per contestualizzare le inefficienze"
    ],
    "output_schema": {
        "type": "object",
        "properties": {
            "efficiency_score": {
                "type": "number",
                "description": "Valore 0-100"
            },
            "gaps": {
                "type": "array",
                "items": {
                    "type": "object",
                    "properties": {
                        "start": {
                            "type": "string"
                        },
                        "end": {
                            "type": "string"
                        },
                        "duration_minutes": {
                            "type": "number"
                        },
                        "fillable": {
                            "type": "boolean"
                        }
                    }
                }
            },
            "issues": {
                "type": "array",
                "items": {
                    "type": "object",
                    "properties": {
                        "type": {
                            "type": "string"
                        },
                        "description": {
                            "type": "string"
                        },
                        "severity": {
                            "type": "string"
                        }
                    }
                }
            },
            "suggestions": {
                "type": "array",
                "items": {
                    "type": "object",
                    "properties": {
                        "action": {
                            "type": "string"
                        },
                        "priority": {
                            "type": "string"
                        },
                        "expected_impact": {
                            "type": "string"
                        }
                    }
                }
            }
        }
    },
    "examples": [
        {
            "input": {
                "appointments": [
                    {
                        "start": "2026-03-23T09:00:00",
                        "end": "2026-03-23T09:30:00",
                        "duration_minutes": 30
                    },
                    {
                        "start": "2026-03-23T10:30:00",
                        "end": "2026-03-23T11:00:00",
                        "duration_minutes": 30
                    }
                ]
            },
            "output": {
                "efficiency_score": 45,
                "gaps": [
                    {
                        "start": "2026-03-23T09:30:00",
                        "end": "2026-03-23T10:30:00",
                        "duration_minutes": 60,
                        "fillable": true
                    }
                ],
                "issues": [
                    {
                        "type": "large_gap",
                        "description": "Gap di 60 minuti tra appuntamenti",
                        "severity": "high"
                    }
                ],
                "suggestions": [
                    {
                        "action": "Inserire seduta di igiene o urgenza",
                        "priority": "high",
                        "expected_impact": "Aumento saturazione agenda"
                    }
                ]
            }
        }
    ]
}