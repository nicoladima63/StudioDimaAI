				</xs:annotation>
			</xs:element>
           	<xs:element minOccurs="0" name="opzioni" type="dt:opzioni">
				<xs:annotation>
					<xs:documentation>Elenco campi opzionali.</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	
	<xs:complexType name="CheckTokenRes">
		<xs:sequence>
			<xs:element minOccurs="1" maxOccurs="1" name="codEsito" type="dt:esitoType">
				<xs:annotation>
					<xs:documentation>Esito della transazione: 0000=Esito positivo e restituzione dati, 0001=Esito positivo (con comunicazioni/warning) e restituzione dati, 9999=errore di sistema.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element minOccurs="0" name="errori" type="dt:errori"/>
			<xs:element minOccurs="0" name="comunicazioni" type="dt:comunicazioni"/>
			<xs:element minOccurs="0" maxOccurs="1" name="infoToken" type="dt:infoToken" />
		</xs:sequence>
	</xs:complexType>
	
</xs:schema>